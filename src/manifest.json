{
    "name": "Link Hinter",
    "version": "0.0.0",
    "manifest_version": 3,
    "description": "Keyboard-driven link navigation with hint overlays",
    "permissions": ["activeTab", "storage"],
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["src/main.tsx"]
        }
    ]
}
